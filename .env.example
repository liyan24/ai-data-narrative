# LLM API Keys
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=          # e.g. https://api.deepseek.com for Deepseek
OPENAI_MODEL=gpt-4o-mini  # e.g. deepseek-chat for Deepseek
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local) base URL
OLLAMA_BASE_URL=http://localhost:11434

# Default judge configuration (JSON list of provider names)
JUDGE_PROVIDERS='["openai:gpt-4","anthropic:claude-3-opus"]'

# App config
DEFAULT_PASS_THRESHOLD=0.60
OUTPUT_DIR=./output
