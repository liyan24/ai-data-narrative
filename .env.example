# AI数据叙事系统 — 环境配置模板
# 复制此文件为 .env 后填入你的配置
# 不提交到 Git（已加 .gitignore）

# ============================================================
# 大模型配置（必填）
# ============================================================
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-latest
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ============================================================
# 数据输入配置
# ============================================================
MAX_FILE_SIZE_MB=50
ENCODING_FALLBACK=utf-8,gbk,gb2312,latin1

# ============================================================
# 输出配置
# ============================================================
OUTPUT_DIR=
REPORT_FORMAT=html
REPORT_TITLE=AI数据叙事报告
REPORT_AUTHOR=AI数据叙事系统

# ============================================================
# 可视化配置
# ============================================================
VIZ_WIDTH=800
VIZ_HEIGHT=500
VIZ_DPI=150
VIZ_FONT=SimHei
VIZ_FONT_SIZE=12

# ============================================================
# 平台发布配置（可选）
# ============================================================
XIAOHONGSHU_ACCOUNT=
WECHAT_APPID=
WECHAT_APPSECRET=

# ============================================================
# 性能优化
# ============================================================
CHUNK_SIZE=100000
MAX_MEMORY_MB=1024
